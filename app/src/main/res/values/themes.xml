<resources xmlns:tools="http://schemas.android.com/tools">

    <!-- ✅ Base application theme without ActionBar -->
    <style name="Theme.Ecommerce" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <!-- Primary brand color (toolbar, button etc.) -->
        <item name="colorPrimary">@color/orange</item>

        <!-- Darker version of primary (status bar etc.) -->
        <item name="colorPrimaryVariant">@color/orange</item>

        <!-- Text/icons on primary color -->
        <item name="colorOnPrimary">@color/white</item>

        <!-- Secondary brand color (FAB, toggles etc.) -->
        <item name="colorSecondary">@color/teal_200</item>

        <!-- Darker secondary color -->
        <item name="colorSecondaryVariant">@color/teal_700</item>

        <!-- Text/icons on secondary color -->
        <item name="colorOnSecondary">@color/black</item>

        <!-- Status bar color -->
        <item name="android:statusBarColor" tools:targetApi="l">?attr/colorPrimaryVariant</item>
    </style>

    <!-- ✅ Optional theme with ActionBar -->
    <style name="Theme.Ecommerce.Actionbar" parent="Theme.MaterialComponents.DayNight.DarkActionBar">
        <!-- Primary brand color -->
        <item name="colorPrimary">@color/orange</item>

        <!-- Darker version of primary -->
        <item name="colorPrimaryVariant">@color/orange</item>

        <!-- Text/icons on primary -->
        <item name="colorOnPrimary">@color/white</item>

        <!-- Secondary brand color -->
        <item name="colorSecondary">@color/teal_200</item>

        <!-- Darker secondary color -->
        <item name="colorSecondaryVariant">@color/teal_700</item>

        <!-- Text/icons on secondary -->
        <item name="colorOnSecondary">@color/black</item>

        <!-- Status bar color -->
        <item name="android:statusBarColor" tools:targetApi="l">?attr/colorPrimaryVariant</item>
    </style>

</resources>




